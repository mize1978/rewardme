<div class="login-card">
  <h1>ログイン</h1>

  <%= form_with url: login_path, local: true do |f| %>
    <div class="form-group">
      <%= label_tag :email, "メールアドレス" %>
      <%= text_field_tag :email, nil, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= label_tag :password, "パスワード" %>
      <%= password_field_tag :password, nil, class: "form-input" %>
    </div>

    <%= submit_tag "ログイン", class: "login-button" %>
  <% end %>
</div>