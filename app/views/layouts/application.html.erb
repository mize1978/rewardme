<!DOCTYPE html>
<html>
  <head>
    <title>RewardMe</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <meta property="og:title" content="RewardMe">
    <meta property="og:description" content="ごほうびでタスクを続けるアプリ🍰">
    <meta property="og:image" content="https://reward-task-app.onrender.com/images/ogp.png">
    <meta property="og:url" content="https://reward-task-app.onrender.com">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="RewardMe">
    <meta name="twitter:description" content="ごほうびでタスクを続けるアプリ🍰">
    <meta name="twitter:image" content="https://reward-task-app.onrender.com/images/ogp.png">

    <link rel="icon" type="image/png" href="/favicon.png">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-room-theme="<%= current_user&.current_room_bg || 'default' %>"
        data-egg-color="<%= current_user&.egg_color || 'pink' %>"
        data-controller="bgm"
        data-bgm-room="<%= current_user ? (current_user.current_room_bg || 'default') : 'login' %>">

    <% unless (controller_name == 'sessions' && action_name == 'new') || (controller_name == 'users' && action_name == 'new') || (controller_name == 'pages' && action_name == 'lp') %>
      <%= render 'shared/header' %>
    <% end %>

    <!-- you found this 😎 crafted by mize -->

    <%= yield %>

    <%= render 'shared/footer' %>
  </body>
</html>