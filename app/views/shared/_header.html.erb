<div class="header header--desktop">
  <%= link_to dashboard_path, class: "header-logo-link" do %>
    <%= image_tag "rewardme_logo.png", class: "header-logo-img", alt: "RewardMe" %>
  <% end %>

  <% if current_user %>
    <div class="header-status">
      <span class="header-lv">★ Lv.<%= current_user.ribbon_level %></span>
      <div class="header-exp-wrap">
        <div class="header-exp-bar">
          <div class="header-exp-fill" style="width: <%= current_user.ribbon_exp_percent %>%;"></div>
        </div>
        <span class="header-exp-text">
          <%= current_user.ribbon_exp %> / <%= current_user.ribbon_exp_max || "MAX" %>
        </span>
      </div>
      <span class="header-stage"><%= current_user.ribbon_stage_name %></span>
      <span class="header-lives">❤️ <%= current_user.lives %> / 5</span>
      <span class="header-coins"><i class="coin-ico"></i><%= number_with_delimiter(current_user.coins) %></span>
      <span class="header-gems">💎 350</span>
    </div>
  <% end %>

  <div class="header-right">
    <% if current_user %>
      <div class="header-icons">

        <%# 🔔 通知ドロップダウン %>
        <% notifs = notification_tasks %>
        <div class="header-notif-wrap" id="notifWrap">
          <button class="header-icon header-icon--btn" id="notifBtn" title="お知らせ" type="button">
            🔔
            <% if notifs.any? %>
              <span class="notif-badge"><%= notifs.count > 9 ? "9+" : notifs.count %></span>
            <% end %>
          </button>

          <div class="notif-dropdown" id="notifDropdown" hidden>
            <p class="notif-dropdown-title">📋 タスクのお知らせ</p>
            <% if notifs.empty? %>
              <p class="notif-empty">期限切れのタスクはないよ ✨</p>
            <% else %>
              <% notifs.each do |task| %>
                <% overdue = task.date < Date.current %>
                <div class="notif-item <%= overdue ? 'notif-item--overdue' : 'notif-item--today' %>">
                  <span class="notif-item-icon"><%= overdue ? '⚠️' : '📅' %></span>
                  <div class="notif-item-body">
                    <span class="notif-item-title"><%= task.title %></span>
                    <span class="notif-item-date">
                      <%= overdue ? "#{(Date.current - task.date).to_i}日延滞" : "今日期限" %>
                    </span>
                  </div>
                </div>
              <% end %>
            <% end %>
            <%= link_to "タスク一覧を見る →", my_tasks_path, class: "notif-footer-link" %>
          </div>
        </div>

        <%# 📮 お手紙 %>
        <% unread_count = current_user.unread_letter_count %>
        <%= link_to letters_path,
              class: "header-mail-btn #{'header-mail-btn--unread' if unread_count > 0}",
              title: "お手紙" do %>
          <% if unread_count > 0 %>
            📮 <span class="header-mail-text">未読 <%= unread_count > 9 ? "9+" : unread_count %></span>
          <% else %>
            <span class="header-mail-text">📮</span>
          <% end %>
        <% end %>

        <%# 🎵 BGM %>
        <div class="bgm-wrap" data-bgm-target="wrap">
          <button class="header-icon header-icon--btn bgm-toggle-btn"
                  data-action="bgm#openPopover"
                  data-bgm-target="btn"
                  title="BGM設定">🎵</button>
          <div class="bgm-popover" data-bgm-target="popover">
            <p class="bgm-popover-title">🎵 BGM音量</p>
            <div class="bgm-volume-row">
              <span class="bgm-vol-icon">🩷</span>
              <input type="range" min="0" max="100" value="30"
                     class="bgm-slider"
                     data-action="input->bgm#setVolume"
                     data-bgm-target="slider">
              <span class="bgm-vol-icon">💜</span>
            </div>
            <button class="bgm-mute-btn"
                    data-action="bgm#toggle"
                    data-bgm-target="muteBtn">🔇 ミュート</button>
          </div>
        </div>

      </div>

      <%# 👤 プロフィールドロップダウン %>
      <div class="header-profile-wrap" id="profileWrap">
        <button class="header-profile-btn" id="profileBtn" type="button">
          <span class="header-profile-name"><%= current_user.nickname %> さん</span>
          <span class="header-profile-caret">▾</span>
        </button>
        <div class="header-profile-dropdown" id="profileDropdown" hidden>
          <%= link_to settings_path, class: "header-profile-item" do %>
            <span>⚙️</span><span>設定</span>
          <% end %>
          <%= button_to "ログアウト", logout_path,
                method: :delete,
                class: "header-profile-item header-profile-item--logout",
                form: { data: { turbo: false } } %>
        </div>
      </div>
    <% else %>
      <%= link_to "ログイン", login_path, class: "header-link" %>
      <%= link_to "ユーザー登録", signup_path, class: "header-link" %>
    <% end %>
  </div>
</div>

<script>
(function() {
  var btn      = document.getElementById('notifBtn');
  var dropdown = document.getElementById('notifDropdown');
  if (btn && dropdown) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      dropdown.hidden = !dropdown.hidden;
      if (!dropdown.hidden) { var pd = document.getElementById('profileDropdown'); if (pd) pd.hidden = true; }
    });
    dropdown.addEventListener('click', function(e) { e.stopPropagation(); });
  }

  var profileBtn      = document.getElementById('profileBtn');
  var profileDropdown = document.getElementById('profileDropdown');
  if (profileBtn && profileDropdown) {
    profileBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      profileDropdown.hidden = !profileDropdown.hidden;
      if (!profileDropdown.hidden) { if (dropdown) dropdown.hidden = true; }
    });
    profileDropdown.addEventListener('click', function(e) { e.stopPropagation(); });
  }

  document.addEventListener('click', function() {
    if (dropdown) dropdown.hidden = true;
    if (profileDropdown) profileDropdown.hidden = true;
  });
})();
</script>

<% if current_user %>
<%# ━━━ モバイル専用 UI ━━━ %>

<%# 固定ヘッダーの高さ分のスペーサー %>
<div class="mobile-top-spacer"></div>

<%# モバイルヘッダー %>
<div class="mobile-header">
  <div class="mobile-header-left">
    <%= link_to dashboard_path, class: "mobile-header-logo-link" do %>
      <%= image_tag "rewardme_logo.png", class: "mobile-header-logo", alt: "RewardMe" %>
    <% end %>
    <span class="mobile-header-greeting">おかえり、<%= current_user.nickname %>！</span>
  </div>
  <button class="mobile-hamburger" id="mobileHamburger" type="button" aria-label="メニュー">
    <span></span><span></span><span></span>
  </button>
</div>

<%# ドロワー背景（タップで閉じる） %>
<div class="mobile-backdrop" id="mobileBackdrop"></div>

<%# ドロワーパネル %>
<div class="mobile-drawer" id="mobileDrawer">
  <div class="mobile-drawer-user">
    <p class="mobile-drawer-name"><%= current_user.nickname %> さん</p>
    <div class="mobile-drawer-stats">
      <span>★ Lv.<%= current_user.ribbon_level %></span>
      <span>🪙 <%= number_with_delimiter(current_user.coins) %></span>
      <span>❤️ <%= current_user.lives %>/5</span>
    </div>
    <div class="mobile-drawer-exp-wrap">
      <div class="mobile-drawer-exp-fill" style="width: <%= current_user.ribbon_exp_percent %>%"></div>
    </div>
    <p class="mobile-drawer-stage"><%= current_user.ribbon_stage_name %></p>
  </div>
  <nav class="mobile-drawer-nav">
    <% unread = current_user.unread_letter_count %>
    <%= link_to letters_path, class: "mobile-drawer-link" do %>
      <span>📮 お手紙</span>
      <% if unread > 0 %>
        <span class="mobile-drawer-badge"><%= unread > 9 ? "9+" : unread %></span>
      <% end %>
    <% end %>
  </nav>
  <div class="mobile-drawer-footer">
    <%= button_to "ログアウト", logout_path,
          method: :delete,
          class: "mobile-drawer-logout",
          form: { data: { turbo: false } } %>
  </div>
</div>

<%# ボトムナビ %>
<nav class="mobile-bottom-nav">
  <%= link_to dashboard_path,
        class: "mobile-nav-item #{'mobile-nav-item--active' if current_page?(dashboard_path)}" do %>
    <span class="mobile-nav-ico">🏠</span>
    <span class="mobile-nav-label">ホーム</span>
  <% end %>
  <%= link_to my_tasks_path,
        class: "mobile-nav-item #{'mobile-nav-item--active' if current_page?(my_tasks_path)}" do %>
    <span class="mobile-nav-ico">📋</span>
    <span class="mobile-nav-label">タスク</span>
  <% end %>
  <%= link_to games_path,
        class: "mobile-nav-item #{'mobile-nav-item--active' if current_page?(games_path)}" do %>
    <span class="mobile-nav-ico">🎮</span>
    <span class="mobile-nav-label">ゲーム</span>
  <% end %>
  <%= link_to shop_path,
        class: "mobile-nav-item #{'mobile-nav-item--active' if current_page?(shop_path)}" do %>
    <span class="mobile-nav-ico">🛍️</span>
    <span class="mobile-nav-label">ショップ</span>
  <% end %>
  <%= link_to settings_path,
        class: "mobile-nav-item #{'mobile-nav-item--active' if current_page?(settings_path)}" do %>
    <span class="mobile-nav-ico">⚙️</span>
    <span class="mobile-nav-label">設定</span>
  <% end %>
</nav>

<script>
(function() {
  var hamburger = document.getElementById('mobileHamburger');
  var drawer    = document.getElementById('mobileDrawer');
  var backdrop  = document.getElementById('mobileBackdrop');
  if (!hamburger || !drawer) return;

  function openDrawer() {
    drawer.classList.add('mobile-drawer--open');
    backdrop.classList.add('mobile-backdrop--show');
    hamburger.classList.add('mobile-hamburger--open');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    drawer.classList.remove('mobile-drawer--open');
    backdrop.classList.remove('mobile-backdrop--show');
    hamburger.classList.remove('mobile-hamburger--open');
    document.body.style.overflow = '';
  }

  hamburger.addEventListener('click', function() {
    drawer.classList.contains('mobile-drawer--open') ? closeDrawer() : openDrawer();
  });
  backdrop.addEventListener('click', closeDrawer);
})();
</script>

<% end %>
