<div class="gacha-scene-bg"></div>
<div class="gacha-page"
     data-controller="gacha"
     data-gacha-pull-url="<%= gacha_pull_path %>">

  <%# ━━━ メイン画面 ━━━ %>
  <div class="gacha-main" data-gacha-target="mainScreen">

    <div class="gacha-hero">
      <p class="gacha-label">✨ ミニゲーム</p>
      <h1 class="gacha-title">リボンガチャ</h1>
      <p class="gacha-sub">コインを使ってレアアイテムをゲット！</p>
    </div>

    <%# ガチャ機ビジュアル %>
    <div class="gacha-ball-display">
      <%= image_tag "gacha_machine.png", class: "gacha-machine-img", alt: "リボンガチャ" %>
    </div>

    <%# コイン残高 %>
    <div class="gacha-wallet">
      <span class="gacha-wallet-ico">🪙</span>
      <span class="gacha-wallet-num" data-gacha-target="coinDisplay"><%= current_user.coins %></span>
      <span class="gacha-wallet-label">コイン</span>
    </div>

    <%# 排出率 %>
    <div class="gacha-rates">
      <div class="gacha-rate-item gacha-rate-item--ssr">SSR <strong>5%</strong></div>
      <div class="gacha-rate-item gacha-rate-item--sr">SR <strong>19%</strong></div>
      <div class="gacha-rate-item gacha-rate-item--r">R <strong>31%</strong></div>
      <div class="gacha-rate-item gacha-rate-item--n">N <strong>45%</strong></div>
    </div>

    <%# 引くボタン %>
    <div class="gacha-pull-btns">
      <button class="gacha-pull-btn gacha-pull-btn--single"
              data-action="gacha#pull"
              data-gacha-count-param="1"
              data-gacha-cost-param="50"
              data-gacha-target="pullBtn"
              <%= current_user.coins < 50 ? "disabled" : "" %>>
        <span class="gacha-pull-btn-main">1回引く</span>
        <span class="gacha-pull-btn-cost">🪙 50コイン</span>
      </button>

      <button class="gacha-pull-btn gacha-pull-btn--ten"
              data-action="gacha#pull"
              data-gacha-count-param="10"
              data-gacha-cost-param="450"
              data-gacha-target="pullBtn"
              <%= current_user.coins < 450 ? "disabled" : "" %>>
        <span class="gacha-pull-btn-main">10連ガチャ</span>
        <span class="gacha-pull-btn-cost">🪙 450コイン <em>（10%お得！）</em></span>
      </button>
    </div>

    <% if current_user.gacha_title.present? %>
      <p class="gacha-current-title">👑 現在の称号: <strong><%= current_user.gacha_title %></strong></p>
    <% end %>
    <%= link_to "← ゲームに戻る", games_path, class: "game-back-link" %>
  </div>

  <%# ━━━ カプセルアニメーション オーバーレイ ━━━ %>
  <div class="gacha-overlay" data-gacha-target="overlay" hidden>
    <div class="gacha-capsule-wrap">
      <div class="gacha-capsule" data-gacha-target="capsule">
        <div class="gacha-capsule-top"></div>
        <div class="gacha-capsule-bottom"></div>
        <div class="gacha-capsule-shine"></div>
      </div>
      <p class="gacha-capsule-label">ドキドキ…🎀</p>
    </div>
  </div>

  <%# ━━━ 結果画面 ━━━ %>
  <div class="gacha-result" data-gacha-target="resultScreen" hidden>
    <%# ━━━ 魔法陣（カード背後） ━━━ %>
    <div class="gacha-magic-bg" aria-hidden="true">
      <div class="gacha-mc-glow"></div>
      <div class="gacha-mc-ring gacha-mc-ring--1"></div>
      <div class="gacha-mc-ring gacha-mc-ring--2"></div>
      <div class="gacha-mc-ring gacha-mc-ring--3"></div>
      <svg class="gacha-mc-svg" viewBox="0 0 300 300" xmlns="http://www.w3.org/2000/svg">
        <circle cx="150" cy="150" r="140" fill="none" stroke="rgba(200,100,255,0.18)" stroke-width="0.8"/>
        <circle cx="150" cy="150" r="120" fill="none" stroke="rgba(255,120,200,0.15)" stroke-width="0.6"/>
        <circle cx="150" cy="150" r="90"  fill="none" stroke="rgba(200,100,255,0.20)" stroke-width="0.8" stroke-dasharray="6 4"/>
        <polygon points="150,20 174,95 252,95 189,140 212,215 150,170 88,215 111,140 48,95 126,95"
                 fill="none" stroke="rgba(220,130,255,0.22)" stroke-width="1.2"/>
        <polygon points="150,60 163,102 207,102 172,127 185,169 150,145 115,169 128,127 93,102 137,102"
                 fill="none" stroke="rgba(255,140,210,0.18)" stroke-width="0.8"/>
        <% 8.times do |i| %>
          <% angle = i * 45 * Math::PI / 180 %>
          <circle cx="<%= (150 + 120 * Math.sin(angle)).round(1) %>"
                  cy="<%= (150 - 120 * Math.cos(angle)).round(1) %>"
                  r="3" fill="rgba(255,160,230,0.35)"/>
        <% end %>
      </svg>
    </div>

    <h2 class="gacha-result-heading">✨ 結果発表！</h2>
    <div class="gacha-cards-area" data-gacha-target="cardsArea"></div>
    <div class="gacha-summary" data-gacha-target="summary"></div>
    <div class="gacha-result-actions">
      <button class="gacha-pull-btn gacha-pull-btn--again"
              data-action="gacha#again"
              data-gacha-target="pullBtn">
        <span class="gacha-pull-btn-main">もう一回！</span>
        <span class="gacha-pull-btn-cost">ガチャに戻る</span>
      </button>
      <%= link_to "← ゲームに戻る", games_path, class: "game-back-link" %>
    </div>
  </div>

</div>
