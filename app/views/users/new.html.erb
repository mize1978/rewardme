<h1>ユーザー登録</h1>

<div class="login-card">
  <%= form_with model: @user, url: signup_path do |f| %>

    <div class="form-group">
      <%= f.label :last_name, "姓" %>
      <%= f.text_field :last_name, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :first_name, "名" %>
      <%= f.text_field :first_name, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :email, "Email" %>
      <%= f.email_field :email, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :password, "Password" %>
      <%= f.password_field :password, class: "form-input" %>
    </div>

    <%= f.submit "登録", class: "login-button" %>

  <% end %>
</div>