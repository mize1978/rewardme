<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="login-page choose-egg-page">

  <div class="login-orbs" aria-hidden="true">
    <div class="login-orb login-orb--1"></div>
    <div class="login-orb login-orb--2"></div>
    <div class="login-orb login-orb--3"></div>
  </div>

  <div class="login-header">
    <%= image_tag "rewardme_logo.png", class: "login-logo-img", alt: "RewardMe" %>
  </div>

  <div class="choose-egg-main">
    <p class="choose-egg-greeting">はじめまして！</p>
    <h1 class="choose-egg-title">
      どのたまごと一緒に<br>冒険を始める？
    </h1>

    <div class="choose-egg-grid" id="eggGrid">

      <%# ピンク %>
      <div class="egg-choice-card egg-choice-card--pink" data-color="pink" data-form="form-pink">
        <div class="egg-choice-glow egg-glow--pink"></div>
        <div class="egg-choice-outer-ring"></div>
        <div class="egg-choice-img-wrap">
          <%= image_tag "stage1_pink.png", class: "egg-choice-img", alt: "リボンのたまご" %>
          <span class="egg-sparkle egg-sparkle--1">✦</span>
          <span class="egg-sparkle egg-sparkle--2">✧</span>
          <span class="egg-sparkle egg-sparkle--3">✦</span>
          <span class="egg-sparkle egg-sparkle--4">✧</span>
        </div>
        <span class="egg-choice-emoji">🩷</span>
        <span class="egg-choice-label">リボンのたまご</span>
        <span class="egg-choice-desc">やさしさと愛情にあふれた子</span>
      </div>

      <%# ブルー %>
      <div class="egg-choice-card egg-choice-card--blue" data-color="blue" data-form="form-blue">
        <div class="egg-choice-glow egg-glow--blue"></div>
        <div class="egg-choice-outer-ring"></div>
        <div class="egg-choice-img-wrap">
          <%= image_tag "stage1_blue.png", class: "egg-choice-img", alt: "星のたまご" %>
          <span class="egg-sparkle egg-sparkle--1" style="--delay:0.3s">✦</span>
          <span class="egg-sparkle egg-sparkle--2" style="--delay:1.1s">✧</span>
          <span class="egg-sparkle egg-sparkle--3" style="--delay:0.7s">✦</span>
          <span class="egg-sparkle egg-sparkle--4" style="--delay:1.8s">✧</span>
        </div>
        <span class="egg-choice-emoji">💙</span>
        <span class="egg-choice-label">星のたまご</span>
        <span class="egg-choice-desc">夢と輝きを秘めた子</span>
      </div>

      <%# パープル %>
      <div class="egg-choice-card egg-choice-card--purple" data-color="purple" data-form="form-purple">
        <div class="egg-choice-glow egg-glow--purple"></div>
        <div class="egg-choice-outer-ring"></div>
        <div class="egg-choice-img-wrap">
          <%= image_tag "stage1_purple.png", class: "egg-choice-img", alt: "ゴシックのたまご" %>
          <span class="egg-sparkle egg-sparkle--1" style="--delay:0.6s">✦</span>
          <span class="egg-sparkle egg-sparkle--2" style="--delay:0s">✧</span>
          <span class="egg-sparkle egg-sparkle--3" style="--delay:1.4s">✦</span>
          <span class="egg-sparkle egg-sparkle--4" style="--delay:0.9s">✧</span>
        </div>
        <span class="egg-choice-emoji">💜</span>
        <span class="egg-choice-label">ゴシックのたまご</span>
        <span class="egg-choice-desc">神秘と輝きをまとった子</span>
      </div>

    </div>

    <p class="choose-egg-note">※能力はすべて同じです。好きな色を選んでね♪</p>
  </div>


  <%# 選択後オーバーレイ %>
  <div class="choose-egg-overlay" id="eggOverlay" aria-hidden="true">
    <div class="choose-egg-overlay-content">
      <div class="choose-egg-chosen-egg" id="chosenEggDisplay"></div>
      <div class="choose-egg-particles" id="eggParticles"></div>
      <div class="choose-egg-result-msg" id="eggResultMsg">
        <span class="choose-egg-sparkle-big">✨</span>
        <p>あなたのパートナーが<br>決まりました！</p>
      </div>
    </div>
  </div>

</div>

<script>
(function() {
  var overlay = document.getElementById('eggOverlay');
  var display = document.getElementById('chosenEggDisplay');
  var msg     = document.getElementById('eggResultMsg');
  var cards   = document.querySelectorAll('.egg-choice-card');
  var busy    = false;

  var glowColors = {
    pink:   'rgba(255, 143, 172, 0.8)',
    blue:   'rgba(100, 160, 255, 0.8)',
    purple: 'rgba(180, 100, 255, 0.8)'
  };

  cards.forEach(function(card) {
    card.addEventListener('click', function() {
      if (busy) return;
      busy = true;

      var color = this.dataset.color;

      cards.forEach(function(c) {
        if (c !== card) c.classList.add('egg-card--dim');
      });
      card.classList.add('egg-card--chosen-pulse');

      setTimeout(function() {
        var eggImg = card.querySelector('.egg-choice-img');
        var eggSrc = eggImg ? eggImg.src : '';

        display.innerHTML = '<img src="' + eggSrc + '" class="chosen-egg-img">';

        spawnParticles(color);
        overlay.classList.add('choose-egg-overlay--show');

        setTimeout(function() {
          msg.classList.add('choose-egg-result-msg--show');
        }, 300);

        setTimeout(function() {
          overlay.classList.add('choose-egg-overlay--fadeout');
          setTimeout(function() {
            submitColor(color);
          }, 500);
        }, 1800);

      }, 400);
    });
  });

  function submitColor(color) {
    window.location.href = '/choose_egg?color=' + encodeURIComponent(color);
  }

  function spawnParticles(color) {
    var container = document.getElementById('eggParticles');
    container.innerHTML = '';
    var symbols = ['✦','✧','★','✨','◇','♡'];
    var count = 24;

    for (var i = 0; i < count; i++) {
      var el = document.createElement('span');
      el.className = 'egg-particle';
      el.textContent = symbols[i % symbols.length];
      var angle = (360 / count) * i;
      var dist  = 120 + Math.random() * 100;
      var size  = 10 + Math.random() * 14;
      var delay = Math.random() * 0.3;
      el.style.cssText = [
        '--angle:' + angle + 'deg',
        '--dist:'  + dist  + 'px',
        '--size:'  + size  + 'px',
        '--delay:' + delay + 's',
        'color:' + glowColors[color]
      ].join(';');
      container.appendChild(el);
    }
  }
})();
</script>
