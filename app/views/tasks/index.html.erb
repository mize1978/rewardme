<%# 通知メッセージ %>
<div class="notice-wrapper">
  <% if notice %>
    <p class="notice"><%= notice %></p>
  <% end %>
</div>

<%# ===== 進化演出オーバーレイ ===== %>
<% if flash[:evolution_stage] %>
  <%
    evo_stage  = flash[:evolution_stage].to_i
    evo_first  = flash[:evolution_first_time] == "true"
    _c = (current_user.egg_color.presence || "pink").to_s
    _c = "purple" if _c == "yellow"
    prev_img   = "stage#{evo_stage - 1}_#{_c}.png"
    new_img    = "stage#{evo_stage}_#{_c}.png"
    stage_names = %w[たまごのリボンちゃん ベビーリボン リボンちゃん プリンセスリボン]
    new_name   = stage_names[evo_stage - 1]
    messages   = { 2 => "はじめまして♪\nこれからよろしくね♡",
                   3 => "もっと一緒にがんばろうね♪\nリボンちゃんになったよ！",
                   4 => "ありがとう…\n最高の姿になれたよ♡\nずっと一緒にいてね。" }
    evo_msg    = messages[evo_stage]
    evo_cls    = evo_stage == 4 ? "evo-overlay--princess" : (evo_stage == 3 ? "evo-overlay--ribbon" : "")
  %>
  <div class="evo-overlay <%= evo_cls %>"
       data-controller="evolution"
       data-evolution-stage-value="<%= evo_stage %>"
       data-evolution-first-time-value="<%= evo_first %>">
    <% if evo_first %>
      <div class="evo-bg"></div>
      <div class="evo-rays"></div>
      <div class="evo-flash"></div>
      <div class="evo-particles">
        <% 14.times do |i| %>
          <span class="evo-particle" style="--i:<%= i %>"><%= %w[✨ 🎀 ⭐ 💫 🌟].sample %></span>
        <% end %>
      </div>
      <div class="evo-card">
        <div class="evo-prev-wrap">
          <%= image_tag prev_img, class: "evo-prev-img" %>
          <% if evo_stage == 3 %>
            <p class="evo-mystery-label">？？？？？</p>
          <% end %>
        </div>
        <div class="evo-new-wrap">
          <%= image_tag new_img, class: "evo-new-img" %>
          <div class="evo-new-glow"></div>
        </div>
        <p class="evo-evolution-label"><%= evo_stage == 4 ? "✨ Congratulations ✨" : "✨ EVOLUTION ✨" %></p>
        <h3 class="evo-new-name"><%= new_name %></h3>
        <p class="evo-message"><%= evo_msg %></p>
        <button class="evo-ok-btn" data-action="click->evolution#close">OK ✨</button>
      </div>
    <% else %>
      <div class="evo-simple">
        <span>✨</span>
        <span><%= new_name %>に進化しました！</span>
      </div>
    <% end %>
  </div>
<% end %>

<div class="dashboard-layout">

  <%# ===== 左カラム: サイドバー ===== %>
  <div class="col-left">
    <%= render 'shared/sidebar' %>
  </div>

  <%# ===== 中央カラム: マイルーム + カレンダー + タスク ===== %>
  <div class="col-center">

    <%# ===== マイルーム ===== %>
    <div class="my-room">
      <%= image_tag current_user.room_bg_image, class: "room-bg", alt: "マイルーム" %>
      <div class="room-egg-tint"></div>
      <span class="room-title">マイルーム</span>
      <span class="room-neon">Good job today!</span>
      <div class="room-character room-character--stage<%= current_user.ribbon_stage %>">
        <div class="room-chara-shake <%= 'near-evo' if current_user.ribbon_stage < 4 && current_user.next_stage_tasks <= 3 %>">
          <%= image_tag current_user.ribbon_stage_image, class: "room-chara-img" %>
        </div>
      </div>
      <div class="room-speech">
        <p class="room-speech-text"
           data-controller="ribbon"
           data-room-bg="<%= current_user.current_room_bg || 'default' %>"
           data-egg-color="<%= current_user.egg_color || 'pink' %>">読み込み中...</p>
      </div>

    </div>

    <div class="center-bottom">

      <div class="week-panel">
        <p class="panel-title">📅 今週の記録</p>
        <div class="week-grid">
          <% %w[月 火 水 木 金 土 日].each_with_index do |label, i| %>
            <div class="week-col">
              <span class="week-label"><%= label %></span>
              <% day = @week_days[i] %>
              <% if day %>
                <div class="week-dot <%= day[:done] ? 'done' : 'empty' %> <%= day[:today] ? 'today' : '' %>">
                  <%= day[:done] ? "✓" : "" %>
                </div>
                <span class="week-date <%= day[:today] ? 'today' : '' %>"><%= day[:date].day %></span>
              <% else %>
                <div class="week-dot future"></div>
                <span class="week-date future">-</span>
              <% end %>
            </div>
          <% end %>
        </div>
        <p class="week-streak">🔥 <%= @streak_days %>日連続</p>

        <div class="week-stats">
          <% week_rate = (@week_done_days * 100.0 / 7).round %>
          <div class="week-stat-item">
            <span class="week-stat-label">今週の達成率</span>
            <span class="week-stat-value week-stat-value--rate">
              <span class="week-stat-bar-wrap">
                <span class="week-stat-bar-fill" style="width: <%= week_rate %>%;"></span>
              </span>
              <%= week_rate %>%
            </span>
          </div>
          <div class="week-stat-item">
            <span class="week-stat-label">今日の完了</span>
            <span class="week-stat-value">📋 <%= @today_done_count %>件</span>
          </div>
          <div class="week-stat-item">
            <span class="week-stat-label">今日のEXP</span>
            <span class="week-stat-value week-stat-value--exp">⭐ +<%= @today_coins %></span>
          </div>
        </div>

        <div class="week-divider"></div>
        <%= link_to games_path, class: "week-games-link" do %>
          <%= image_tag "icon_game_ribbon.png", class: "week-games-link-icon", alt: "" %>
          <span>ミニゲームで遊ぶ</span>
          <span class="week-games-link-arrow">→</span>
        <% end %>
      </div>

      <div class="tasks-panel">
        <div class="tasks-panel-header">
          <p class="panel-title">今日のタスク</p>
          <%= link_to "+ 追加", new_task_path, class: "tasks-add-btn" %>
        </div>

        <div class="tasks-benny-row" data-controller="benny">
          <div class="tasks-benny-float">
            <%= image_tag current_user.benny_image,
                  class: "tasks-benny-img",
                  alt: "ベニーリボン",
                  "data-benny-target": "img" %>
          </div>
          <div class="tasks-benny-bubble" data-benny-target="bubble">
            <% if @done_tasks.any? && @not_done_tasks.empty? %>
              今日も全部終わったね！🎉
            <% elsif @not_done_tasks.any? %>
              一緒にがんばろうね♡
            <% else %>
              今日は何から始める？♡
            <% end %>
          </div>
        </div>

        <div id="not-done-tasks">
          <% if @not_done_tasks.empty? %>
            <% if @done_tasks.any? %>
              <div class="tasks-all-done">
                <%= image_tag "puzzle_11.png", class: "tasks-all-done-img", alt: "今日も全部終わったね！" %>
                <p class="tasks-all-done-msg">今日も全部終わったね！🎉</p>
              </div>
            <% else %>
              <div class="tasks-zero-chips">
                  <% [
                    { emoji: "💪", label: "ストレッチ",     category: "health", priority: "low"    },
                    { emoji: "🧹", label: "部屋を片付ける", category: "other",  priority: "medium" },
                    { emoji: "💧", label: "水を飲む",       category: "health", priority: "low"    },
                    { emoji: "📚", label: "読書",           category: "study",  priority: "medium" },
                    { emoji: "🚶", label: "散歩",           category: "health", priority: "low"    },
                  ].each do |t| %>
                    <%= button_to tasks_path,
                          method: :post,
                          class: "tasks-zero-chip",
                          params: { task: { title: t[:label], category: t[:category], priority: t[:priority], date: Time.current.in_time_zone("Tokyo").to_date, done: false } } do %>
                      <span><%= t[:emoji] %> <%= t[:label] %></span>
                      <span class="tasks-zero-chip-plus">＋</span>
                    <% end %>
                  <% end %>
                </div>
            <% end %>
          <% else %>
            <% @not_done_tasks.each do |task| %>
              <div class="task-card <%= "priority-#{task.priority}" %>">
                <div class="task-card-inner">
                  <%= button_to "", task_path(task, task: { done: true }), method: :patch, class: "task-circle-btn" %>
                  <span class="task-title-text"><%= task.title %></span>
                  <div class="task-right">
                    <span class="category-chip category-<%= task.category %>"><%= task.category %></span>
                    <span class="task-star">★</span>
                    <span class="task-exp"><%= task.coin_reward %> EXP</span>
                  </div>
                  <%= button_to "×", task_path(task), method: :delete, class: "task-delete-btn" %>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
        <% total = @not_done_tasks.count + @done_tasks.count %>
        <% if total > 0 %>
          <div class="tasks-panel-footer">
            <span class="tasks-footer-count"><%= @done_tasks.count %> / <%= total %> 完了</span>
            <% if @not_done_tasks.any? %>
              <% remaining_coins = @not_done_tasks.sum(&:coin_reward) %>
              <span class="tasks-footer-reward">🎁 全部終わると +<%= remaining_coins %>コイン</span>
            <% end %>
          </div>
        <% end %>
      </div>

    </div>

    <%# ===== お部屋の成長ストリップ（ダミー表示） ===== %>
    <div class="room-growth-panel">
      <div class="room-growth-head">
        <p class="panel-title">🏠 お部屋の成長</p>
        <span class="room-growth-sub">タスクをこなすほどお部屋がにぎやかに！</span>
      </div>
      <div class="room-growth-strip">
        <% ["0〜10", "11〜30", "31〜50", "51〜100", "101〜150", "151〜200"].each_with_index do |label, i| %>
          <div class="room-growth-item <%= 'current' if i.zero? %>">
            <%= image_tag "room_stage_1.png", class: "room-growth-img" %>
            <span class="room-growth-label"><%= label %>タスク</span>
          </div>
          <% if i < 5 %><span class="room-growth-arrow">›</span><% end %>
        <% end %>
      </div>
    </div>

  </div>

  <%# ===== 右カラム: 進化 + バッジ + 統計 + デコ ===== %>
  <div class="col-right">

    <%# リボンちゃんの成長（横並び進化チェーン） %>
    <%
      _color = (current_user.egg_color.presence || "pink").to_s
      _color = "purple" if _color == "yellow"
      evo_stages = [
        { stage: 1, name: "たまごのリボンちゃん", lv: 1,  image: "stage1_#{_color}.png" },
        { stage: 2, name: "ベビーリボン",         lv: 10, image: "stage2_#{_color}.png" },
        { stage: 3, name: "リボンちゃん",         lv: 20, image: "stage3_#{_color}.png" },
        { stage: 4, name: "プリンセスリボン",     lv: 40, image: "stage4_#{_color}.png" },
      ]
      cur_stage = current_user.ribbon_stage
    %>
    <div class="evo-chain-panel">
      <p class="panel-title">🎀 リボンちゃんの成長</p>

      <div class="evo-vertical-chain">
        <% evo_stages.each_with_index do |s, i| %>
          <% is_current      = (s[:stage] == cur_stage) %>
          <% is_unlocked    = (s[:stage] < cur_stage) %>
          <% just_evolved   = flash[:evolution_stage].to_i == s[:stage] %>
          <div class="evo-v-item <%= is_current ? 'evo-v-item--current' : (is_unlocked ? 'evo-v-item--unlocked' : '') %> <%= 'evo-v-item--just-evolved' if just_evolved %>">
            <div class="evo-v-img-wrap">
              <%= image_tag s[:image], class: "evo-v-img", alt: s[:name] %>
              <% if is_current %>
                <span class="evo-v-badge">✨ 今ここ！</span>
              <% elsif is_unlocked %>
                <span class="evo-v-check">✓</span>
              <% end %>
            </div>
            <div class="evo-v-info">
              <p class="evo-v-name"><%= s[:name] %></p>
              <p class="evo-v-lv">Lv.<%= s[:lv] %> ~</p>
              <% if is_current && cur_stage < 4 %>
                <div class="evo-v-progress">
                  <div class="evo-v-fill" style="width: <%= current_user.ribbon_exp_percent %>%;"></div>
                </div>
                <p class="evo-v-progress-text">あと <strong><%= current_user.next_stage_tasks %></strong> タスクで進化！</p>
              <% elsif is_current && cur_stage == 4 %>
                <p class="evo-v-max">👑 最終進化達成！</p>
              <% end %>
            </div>
          </div>
          <% if i < evo_stages.length - 1 %>
            <div class="evo-v-arrow">↓</div>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# バッジコレクション（ダミー） %>
    <div class="badge-panel">
      <p class="panel-title">🏅 バッジコレクション</p>
      <div class="badge-grid">
        <% [
          { ico: "🌱", name: "はじめの一歩",       earned: true  },
          { ico: "🏆", name: "継続は力なり",       earned: true  },
          { ico: "⏰", name: "時間マスター",       earned: false },
          { ico: "👑", name: "タスクマスター",     earned: false },
          { ico: "🎂", name: "パーフェクトウィーク", earned: false }
        ].each do |b| %>
          <div class="badge-item <%= 'earned' if b[:earned] %>">
            <span class="badge-ico"><%= b[:ico] %></span>
            <span class="badge-name"><%= b[:name] %></span>
          </div>
        <% end %>
      </div>
      <p class="badge-note">獲得したバッジはお部屋に飾られるよ！</p>
      <div class="badge-current-row">いま獲得中：<%= current_user.badge %></div>
    </div>

    <%# 今週のステータス + RPリング %>
    <div class="stats-panel">
      <p class="panel-title">📊 今週のステータス</p>

      <% rp      = current_user.coins %>
      <% rp_goal = 3000 %>
      <% rp_pct  = rp_goal.zero? ? 0 : ((rp.to_f / rp_goal) * 100).round.clamp(0, 100) %>
      <div class="rp-row">
        <div class="rp-info">
          <span class="rp-label">リワードポイント (RP)</span>
          <span class="rp-value"><%= number_with_delimiter(rp) %><small> RP</small></span>
          <div class="rp-bar"><div class="rp-fill" style="width: <%= rp_pct %>%;"></div></div>
          <span class="rp-goal">今週の目標 <%= number_with_delimiter(rp_goal) %> RP</span>
        </div>
        <div class="rp-ring" style="--pct: <%= rp_pct %>;">
          <span class="rp-ring-text"><%= rp_pct %>%</span>
        </div>
      </div>

      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-label">🎉 今日の完了</span>
          <span class="stat-value"><%= @today_done_count %> 個</span>
        </div>
        <div class="stat-item">
          <span class="stat-label">🔥 連続記録</span>
          <span class="stat-value"><%= @streak_days %> 日</span>
        </div>
        <div class="stat-item">
          <span class="stat-label">✅ 総完了数</span>
          <span class="stat-value"><%= @total_count %> 個</span>
        </div>
      </div>
    </div>


  </div>

</div>

<script>
(function() {
  function launchConfetti() {
    var colors = ["#ff6eb4","#c97cff","#ffd700","#7ee8ff","#ff9ef0","#a8f0a0"]
    var wrap = document.createElement("div")
    wrap.className = "confetti-wrap"
    document.body.appendChild(wrap)
    for (var i = 0; i < 72; i++) {
      var p = document.createElement("div")
      p.className = "confetti-piece"
      p.style.cssText =
        "left:"+(Math.random()*100)+"%;"+
        "background:"+colors[i % colors.length]+";"+
        "animation-delay:"+(Math.random()*0.9)+"s;"+
        "animation-duration:"+(1.3+Math.random()*1.3)+"s;"+
        "width:"+(5+Math.random()*8)+"px;"+
        "height:"+(5+Math.random()*8)+"px;"+
        "border-radius:"+(Math.random()>0.5?"50%":"3px")+";"+
        "transform:rotate("+(Math.random()*360)+"deg);"
      wrap.appendChild(p)
    }
    setTimeout(function(){ wrap.remove() }, 3500)
  }

  function initTaskPage() {
    // 全完了 → 紙吹雪
    if (document.querySelector(".tasks-all-done")) launchConfetti()

    // タスクチェック → ルームキャラがジャンプ
    document.querySelectorAll(".task-circle-btn").forEach(function(btn) {
      btn.addEventListener("pointerdown", function() {
        var img = document.querySelector(".room-chara-img")
        if (!img) return
        img.classList.remove("room-chara--jump")
        void img.offsetWidth
        img.classList.add("room-chara--jump")
        setTimeout(function(){ img.classList.remove("room-chara--jump") }, 650)
      })
    })
  }

  document.addEventListener("turbo:load", initTaskPage)
  document.addEventListener("DOMContentLoaded", initTaskPage)
})()
</script>
