<%= form_with(model: task, local: true) do |form| %>

  <% if task.errors.any? %>
    <div class="tf-errors">
      <% task.errors.full_messages.each do |message| %>
        <p><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <div class="tf-group">
    <%= form.label :title, "やること", class: "tf-label" %>
    <%= form.text_field :title, class: "form-input", placeholder: "例：RUNTEQの課題やる！" %>
  </div>

  <div class="tf-row">
    <div class="tf-group">
      <%= form.label :priority, "優先度", class: "tf-label" %>
      <%= form.select :priority, [["🔥 高", "high"], ["🌼 中", "medium"], ["🌱 低", "low"]], {}, class: "form-input tf-select" %>
    </div>
    <div class="tf-group">
      <%= form.label :category, "カテゴリ", class: "tf-label" %>
      <%= form.select :category, Task::CATEGORIES, {}, class: "form-input tf-select" %>
    </div>
  </div>

  <div class="tf-group">
    <%= form.label :date, "日付", class: "tf-label" %>
    <%= form.date_field :date, class: "form-input", value: task.date || Time.current.in_time_zone("Tokyo").to_date %>
  </div>

  <div class="tf-check">
    <%= form.check_box :done, class: "tf-checkbox" %>
    <%= form.label :done, "もう終わった？", class: "tf-check-label" %>
  </div>

  <%= form.submit task.new_record? ? "✦ タスクを追加する ✦" : "✦ 更新する ✦", class: "login-btn-new" %>

<% end %>
