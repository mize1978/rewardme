<%# =====================
   タスク表示用パーツ（1件分）
===================== %>

<%# divにタスクごとのユニークIDをつける（例: task_1） %>
<div id="<%= dom_id task %>">

  <%# ---------------------
     タイトル表示
  --------------------- %>
  <p>
    <%# ラベル（太字） %>
    <strong>Title:</strong>

    <%# タスクのタイトル（DBの値） %>
    <%= task.title %>
  </p>

  <%# ---------------------
     完了状態
  --------------------- %>
  <p>
    <%# ラベル %>
    <strong>Done:</strong>

    <%# true / false が表示される（完了してるかどうか） %>
    <%# trueなら完了・falseなら未完了 %>
    <%= task.done %>
  </p>

</div>