<%# ===== ライトボックス ===== %>
<div id="lp-lightbox" class="lp-lightbox" aria-hidden="true">
  <div class="lp-lightbox-backdrop"></div>
  <div class="lp-lightbox-content"></div>
  <button class="lp-lightbox-close" aria-label="閉じる">✕</button>
</div>

<%# ===== JS ===== %>
<script>
(function() {
  /* ── スクロールアニメーション ── */
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (!entry.isIntersecting) return;
      var el = entry.target;
      var delay = parseInt(el.style.getPropertyValue('--reveal-delay')) || 0;
      setTimeout(function() { el.classList.add('lp-revealed'); }, delay);
      observer.unobserve(el);
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -48px 0px' });

  document.querySelectorAll('.lp-reveal, .lp-reveal-left, .lp-reveal-right').forEach(function(el) {
    observer.observe(el);
  });

  /* ── ホバーで画像拡大 ── */
  document.querySelectorAll('.lp-browser-frame--lg, .lp-hero2-frame').forEach(function(frame) {
    var img = frame.querySelector('.lp-screen-room-bg');
    if (!img) return;
    frame.addEventListener('mouseenter', function() { img.style.transform = 'scale(1.05)'; });
    frame.addEventListener('mouseleave', function() { img.style.transform = 'scale(1)'; });
  });

  /* ── ライトボックス ── */
  var lightbox = document.getElementById('lp-lightbox');
  var lbContent = lightbox.querySelector('.lp-lightbox-content');

  function openLightbox(frame) {
    lbContent.innerHTML = '';
    var clone = frame.cloneNode(true);
    clone.removeAttribute('data-lightbox');
    clone.style.cursor = 'default';
    clone.style.maxWidth = '900px';
    clone.style.width = '100%';
    var hint = clone.querySelector('.lp-frame-zoom-hint');
    if (hint) hint.remove();
    lbContent.appendChild(clone);
    lightbox.classList.add('lp-lightbox--open');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('lp-lightbox--open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('[data-lightbox]').forEach(function(frame) {
    frame.style.cursor = 'zoom-in';
    frame.addEventListener('click', function() { openLightbox(frame); });
  });

  lightbox.querySelector('.lp-lightbox-backdrop').addEventListener('click', closeLightbox);
  lightbox.querySelector('.lp-lightbox-close').addEventListener('click', closeLightbox);
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeLightbox(); });

  /* ── スムーズスクロール ── */
  document.querySelectorAll('a[href^="#"]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      var target = document.querySelector(a.getAttribute('href'));
      if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth' }); }
    });
  });
})();
</script>

