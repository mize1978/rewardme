<%# ===== NAV ===== %>
<nav class="lp-nav">
  <div class="lp-nav-inner">
    <%= image_tag "rewardme_logo.png", class: "lp-nav-logo", alt: "RewardMe" %>
    <div class="lp-nav-anchors">
      <a href="#features"  class="lp-nav-anchor">特徴</a>
      <a href="#screens"   class="lp-nav-anchor">画面</a>
      <a href="#portfolio" class="lp-nav-anchor">GitHub</a>
    </div>
    <div class="lp-nav-links">
      <%= link_to "ログイン", login_path, class: "lp-nav-login" %>
      <%= link_to "無料ではじめる", signup_path, class: "lp-nav-cta" %>
    </div>
  </div>
</nav>

<%# ===== HERO（2カラム）===== %>
<section class="lp-hero2">
  <div class="lp-hero2-bg">
    <div class="lp-hero2-orb lp-hero2-orb--1"></div>
    <div class="lp-hero2-orb lp-hero2-orb--2"></div>
    <div class="lp-hero2-orb lp-hero2-orb--3"></div>
  </div>

  <div class="lp-hero2-2col">
    <%# ① 左カラム：コピー ＋ キャラ %>
    <div class="lp-hero2-left">
      <div class="lp-hero2-eyebrow">
        <span class="lp-hero2-eyebrow-dot"></span>
        GAME × PRODUCTIVITY
        <span class="lp-hero2-eyebrow-dot"></span>
      </div>

      <div class="lp-hero2-chara-wrap">
        <%= image_tag "stage4_pink.png", class: "lp-hero2-chara", alt: "リボンちゃん" %>
        <div class="lp-hero2-chara-glow"></div>
      </div>

      <div class="lp-hero2-social">
        <span class="lp-hero2-stars">★★★★★</span>
        <span class="lp-hero2-social-text">200人以上が毎日利用中</span>
      </div>

      <%# ① キャッチコピー %>
      <h1 class="lp-hero2-tagline">
        タスクが、<br>
        毎日<span class="lp-hero2-accent">ちょっと</span><br>
        楽しみになる。
      </h1>
      <p class="lp-hero2-sub">
        リボンちゃんと一緒に、ゲーム感覚で続けるタスク管理。<br>
        こなすほど育つキャラクター・毎日のガチャ・あなただけのマイルーム。
      </p>

      <div class="lp-hero2-btns">
        <%= link_to signup_path, class: "lp-btn-primary lp-btn-large" do %>
          🎀 無料ではじめる
        <% end %>
        <%= link_to login_path, class: "lp-btn-ghost" do %>
          ログイン
        <% end %>
      </div>
      <p class="lp-hero2-note">登録無料・クレジットカード不要</p>
    </div>

    <%# 右カラム：ダッシュボードスクリーンショット %>
    <div class="lp-hero2-right">
      <div class="lp-hero2-frame-shell">
        <div class="lp-hero2-frame-glow lp-hero2-frame-glow--1"></div>
        <div class="lp-hero2-frame-glow lp-hero2-frame-glow--2"></div>
        <div class="lp-browser-frame lp-hero2-frame" data-lightbox>
          <div class="lp-browser-bar">
            <span class="lp-browser-dot"></span>
            <span class="lp-browser-dot"></span>
            <span class="lp-browser-dot"></span>
            <span class="lp-browser-url">reward-task-app.onrender.com/dashboard</span>
          </div>
          <div class="lp-browser-screen lp-screen--shot">
            <%= image_tag "lp_screen_dash_crop.jpg", class: "lp-shot-img", alt: "ダッシュボード" %>
          </div>
        </div>
        <div class="lp-hero2-frame-deco lp-hero2-frame-deco--tl">✨</div>
        <div class="lp-hero2-frame-deco lp-hero2-frame-deco--br">🎀</div>
      </div>
      <p class="lp-hero2-frame-hint">クリックで拡大 🔍</p>
    </div>
  </div>

  <div class="lp-hero2-scroll">
    <span>スクロールで続きを見る</span>
    <span class="lp-hero2-scroll-arrow">↓</span>
  </div>
</section>

<%# ===== ソーシャルプルーフ（Key Addition）===== %>
<section class="lp-proof">
  <div class="lp-proof-inner">
    <div class="lp-proof-left">
      <span class="lp-proof-stars">★★★★★</span>
      <p class="lp-proof-catch">ゲーム感覚で続けられる<strong>「タスク管理」</strong></p>
    </div>
    <div class="lp-proof-divider"></div>
    <div class="lp-proof-metrics">
      <div class="lp-proof-item">
        <span class="lp-proof-ico">📈</span>
        <span class="lp-proof-label">習慣化サポート</span>
      </div>
      <div class="lp-proof-item">
        <span class="lp-proof-ico">✨</span>
        <span class="lp-proof-label">毎日のガチャ</span>
      </div>
      <div class="lp-proof-item">
        <span class="lp-proof-ico">🌱</span>
        <span class="lp-proof-label">キャラ育成</span>
      </div>
      <div class="lp-proof-item">
        <span class="lp-proof-ico">🏠</span>
        <span class="lp-proof-label">部屋カスタム</span>
      </div>
      <div class="lp-proof-item">
        <span class="lp-proof-ico">🎮</span>
        <span class="lp-proof-label">ミニゲーム5種</span>
      </div>
    </div>
  </div>
</section>

<%# ===== キャラクターショーケース ===== %>
<section class="lp-chara-showcase">
  <div class="lp-chara-showcase-header lp-reveal">
    <p class="lp-chara-showcase-eyebrow">3色 × 4段階進化</p>
    <h2 class="lp-chara-showcase-title">あなただけの<span class="lp-hero2-accent">リボンちゃん</span>を育てよう</h2>
    <p class="lp-chara-showcase-sub">好きな色を選んで、タスクをこなすほど進化していく。</p>
  </div>
  <div class="lp-chara-cards">
    <div class="lp-chara-card lp-chara-card--pink lp-reveal" style="--reveal-delay:0ms">
      <div class="lp-chara-card-badge">🎀 ピンク <span class="lp-chara-badge-en">Love</span></div>
      <div class="lp-chara-card-img-wrap">
        <%= image_tag "stage4_pink.png", class: "lp-chara-card-img", alt: "ピンクリボンちゃん" %>
      </div>
      <h3 class="lp-chara-card-name">ピンク</h3>
      <p class="lp-chara-card-desc">優しく応援してくれる。<br>「えらい！」って<br>毎日褒めてくれる。</p>
      <div class="lp-chara-card-tags">
        <span>やさしい</span><span>応援</span><span>癒し</span>
      </div>
    </div>
    <div class="lp-chara-card lp-chara-card--purple lp-reveal" style="--reveal-delay:100ms">
      <div class="lp-chara-card-badge">💜 パープル <span class="lp-chara-badge-en">Mystic</span></div>
      <div class="lp-chara-card-img-wrap">
        <%= image_tag "stage4_purple.png", class: "lp-chara-card-img", alt: "パープルリボンちゃん" %>
      </div>
      <h3 class="lp-chara-card-name">パープル</h3>
      <p class="lp-chara-card-desc">クールに見守る存在。<br>本気になったとき、<br>一番頼りになる。</p>
      <div class="lp-chara-card-tags">
        <span>クール</span><span>ミステリアス</span><span>強さ</span>
      </div>
    </div>
    <div class="lp-chara-card lp-chara-card--blue lp-reveal" style="--reveal-delay:200ms">
      <div class="lp-chara-card-badge">💙 ブルー <span class="lp-chara-badge-en">Active</span></div>
      <div class="lp-chara-card-img-wrap">
        <%= image_tag "stage4_blue.png", class: "lp-chara-card-img", alt: "ブルーリボンちゃん" %>
      </div>
      <h3 class="lp-chara-card-name">ブルー</h3>
      <p class="lp-chara-card-desc">元気いっぱい、いつも前向き。<br>「今日もやった！」を<br>一緒に喜んでくれる。</p>
      <div class="lp-chara-card-tags">
        <span>元気</span><span>アクティブ</span><span>前向き</span>
      </div>
    </div>
  </div>
</section>

<%# ===== 特徴 ===== %>
<section class="lp-features" id="features">
  <div class="lp-section-inner">
    <h2 class="lp-section-title lp-reveal">なぜ RewardMe？</h2>
    <div class="lp-features-grid">
      <div class="lp-feature-card lp-reveal" style="--reveal-delay: 0ms">
        <div class="lp-feature-img-wrap">
          <div class="lp-feature-mini-browser">
            <%= image_tag "lp_screen_dash_crop.jpg", class: "lp-feature-mini-shot", alt: "" %>
          </div>
        </div>
        <h3 class="lp-feature-title">ゲーム感覚で続く</h3>
        <p class="lp-feature-desc">タスクを完了するたびにEXPとコインを獲得。毎日のミニゲームで達成感が習慣を作る。</p>
        <div class="lp-game-lineup">
          <div class="lp-game-chip">
            <span class="lp-game-chip-ico">🧪</span>
            <span class="lp-game-chip-name">リボンポーション</span>
            <span class="lp-game-chip-sub">魔法陣錬成パズル</span>
          </div>
          <div class="lp-game-chip">
            <span class="lp-game-chip-ico">🧩</span>
            <span class="lp-game-chip-name">リボンパズル</span>
            <span class="lp-game-chip-sub">スライドパズル</span>
          </div>
          <div class="lp-game-chip">
            <span class="lp-game-chip-ico">✨</span>
            <span class="lp-game-chip-name">リボンマッチ</span>
            <span class="lp-game-chip-sub">60秒マッチ3</span>
          </div>
          <div class="lp-game-chip">
            <span class="lp-game-chip-ico">🎀</span>
            <span class="lp-game-chip-name">リボンキャッチ</span>
            <span class="lp-game-chip-sub">30秒タップ</span>
          </div>
          <div class="lp-game-chip">
            <span class="lp-game-chip-ico">🎲</span>
            <span class="lp-game-chip-name">ガチャ</span>
            <span class="lp-game-chip-sub">コインで挑戦</span>
          </div>
          <div class="lp-game-chip lp-game-chip--soon">
            <span class="lp-game-chip-ico">🚧</span>
            <span class="lp-game-chip-name">リボンクエスト</span>
            <span class="lp-game-chip-sub">Coming Soon</span>
          </div>
        </div>
      </div>
      <div class="lp-feature-card lp-reveal" style="--reveal-delay: 90ms">
        <div class="lp-feature-img-wrap">
          <div class="lp-feature-evo-mini">
            <%= image_tag "stage1_pink.png", class: "lp-feature-evo-img", alt: "" %>
            <span class="lp-feature-evo-arrow">›</span>
            <%= image_tag "stage2_pink.png", class: "lp-feature-evo-img", alt: "" %>
            <span class="lp-feature-evo-arrow">›</span>
            <%= image_tag "stage4_pink.png", class: "lp-feature-evo-img lp-feature-evo-img--final", alt: "" %>
          </div>
        </div>
        <h3 class="lp-feature-title">キャラクターを育てる</h3>
        <p class="lp-feature-desc">ピンク・パープル・ブルーの3色から選べるリボンちゃん。タスクをこなすごとに4段階で進化する。</p>
        <ul class="lp-feature-list">
          <li>✔ 3色から選べるカラー</li>
          <li>✔ 4段階の進化システム</li>
          <li>✔ レベルアップ演出</li>
          <li>✔ ルーム×キャラコンボ</li>
        </ul>
      </div>
      <div class="lp-feature-card lp-reveal" style="--reveal-delay: 180ms">
        <div class="lp-feature-img-wrap">
          <%= image_tag "gacha_machine.png", class: "lp-feature-gacha-img", alt: "" %>
        </div>
        <h3 class="lp-feature-title">毎日のリボンBOX</h3>
        <p class="lp-feature-desc">1日1回のガチャでコインや特典をゲット。毎朝アプリを開く理由ができる。</p>
        <ul class="lp-feature-list">
          <li>✔ 1日1回の開封チャンス</li>
          <li>✔ コイン・アイテム獲得</li>
          <li>✔ レアリティ判定付き</li>
          <li>✔ ログインボーナス感</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<%# ===== スクリーンショット ===== %>
<section class="lp-screens" id="screens">
  <div class="lp-section-inner">
    <h2 class="lp-section-title lp-reveal">実際の画面をみてみよう</h2>

    <div class="lp-screens-grid">

      <%# 01 ダッシュボード（フィーチャードカード） %>
      <div class="lp-screen-card lp-screen-card--featured lp-reveal">
        <div class="lp-screen-card-hd">
          <span class="lp-screen-num">01</span>
          <h3 class="lp-screen-info-title">マイルームダッシュボード</h3>
        </div>
        <p class="lp-screen-card-desc">キャラクターが住むマイルームでタスクを管理。毎日の達成状況を一目で確認できます。</p>
        <div class="lp-screen-featured-body">
          <div class="lp-browser-frame lp-screen-featured-frame" data-lightbox>
            <div class="lp-browser-bar">
              <span class="lp-browser-dot"></span><span class="lp-browser-dot"></span><span class="lp-browser-dot"></span>
              <span class="lp-browser-url">…/dashboard</span>
            </div>
            <div class="lp-browser-screen lp-screen--shot lp-screen--shot-lg">
              <%= image_tag "lp_screen_dash_crop.jpg", class: "lp-shot-img", alt: "マイルームダッシュボード" %>
            </div>
            <div class="lp-frame-zoom-hint">🔍 クリックで拡大</div>
          </div>
          <div class="lp-screen-featured-side">
            <p class="lp-screen-featured-label">主な機能</p>
            <ul class="lp-screen-featured-list">
              <li>🏠 キャラクターと暮らすマイルーム</li>
              <li>📅 今週の記録（7日間トラッカー）</li>
              <li>✅ 今日のタスク一覧</li>
              <li>✨ ガチャミニパネル</li>
              <li>🎀 リボンキャッチゲーム</li>
              <li>📊 バッジ & ステータス</li>
            </ul>
            <div class="lp-screen-tags">
              <span>グラスモーフィズム</span><span>Stimulus.js</span><span>18種類の部屋テーマ</span>
            </div>
          </div>
        </div>
      </div>

      <%# 02 デイリーBOX %>
      <div class="lp-screen-card lp-screen-card--featured lp-reveal">
        <div class="lp-screen-card-hd">
          <span class="lp-screen-num">02</span>
          <h3 class="lp-screen-info-title">デイリーBOX ガチャ</h3>
        </div>
        <p class="lp-screen-card-desc">1日1回だけ開けられる特別なBOX。コインやレアアイテムが手に入る毎日のお楽しみ。</p>
        <div class="lp-screen-featured-body">
          <div class="lp-browser-frame lp-browser-frame--grid" data-lightbox>
            <div class="lp-browser-bar">
              <span class="lp-browser-dot"></span><span class="lp-browser-dot"></span><span class="lp-browser-dot"></span>
              <span class="lp-browser-url">…/dashboard</span>
            </div>
            <div class="lp-browser-screen lp-screen--box">
              <div class="lp-mockbox-panel">
                <p class="lp-mockbox-title">🎁 今日のリボンBOX</p>
                <div class="lp-mockbox-img-wrap">
                  <%= image_tag "ribbon_box.png", class: "lp-mockbox-img lp-mockbox-float", alt: "" %>
                </div>
                <div class="lp-mockbox-btn">✨ タップして開ける！</div>
                <div class="lp-mockbox-result">
                  <span class="lp-mockbox-ico">🪙</span>
                  <span class="lp-mockbox-label">コイン 100</span>
                  <span class="lp-mockbox-rarity" data-rarity="good">GOOD</span>
                </div>
              </div>
            </div>
            <div class="lp-frame-zoom-hint">🔍 クリックで拡大</div>
          </div>
          <div class="lp-screen-featured-side">
            <p class="lp-screen-featured-label">主な機能</p>
            <ul class="lp-screen-featured-list">
              <li>🎁 1日1回の開封チャンス</li>
              <li>🪙 コイン・アイテム獲得</li>
              <li>✨ レアリティ判定付き</li>
              <li>📅 毎日のログインボーナス</li>
              <li>🎰 加重ガチャで公平設計</li>
            </ul>
            <div class="lp-screen-tags">
              <span>CSSアニメーション</span><span>Fetch API</span><span>加重ガチャ</span>
            </div>
          </div>
        </div>
      </div>

      <%# 03 進化 %>
      <div class="lp-screen-card lp-reveal">
        <div class="lp-screen-card-hd">
          <span class="lp-screen-num">03</span>
          <h3 class="lp-screen-info-title">キャラクター進化システム</h3>
        </div>
        <p class="lp-screen-card-desc">タスクをこなすほど、リボンちゃんが育っていく。たまご・ベビー・リボンちゃん・プリンセスの4段階で進化。毎日続けるほどキャラクターが変わるので、習慣が楽しみになる。</p>
        <div class="lp-browser-frame lp-browser-frame--grid" data-lightbox>
          <div class="lp-browser-bar">
            <span class="lp-browser-dot"></span><span class="lp-browser-dot"></span><span class="lp-browser-dot"></span>
            <span class="lp-browser-url">…/dashboard</span>
          </div>
          <div class="lp-browser-screen lp-screen--evo">
            <p class="lp-mockevo-title">🌸 リボンちゃんの成長</p>
            <div class="lp-mockevo-chain">
              <% [
                { img: "stage1_pink.png", name: "たまご",       done: true    },
                { img: "stage2_pink.png", name: "ベビー",        done: true    },
                { img: "stage3_pink.png", name: "リボンちゃん", current: true },
                { img: "stage4_pink.png", name: "プリンセス"                   },
              ].each_with_index do |s, i| %>
                <% cls = s[:current] ? '--current' : (s[:done] ? '--done' : '--locked') %>
                <div class="lp-mockevo-item lp-mockevo-item<%= cls %>">
                  <%= image_tag s[:img], class: "lp-mockevo-img", alt: s[:name] %>
                  <% if s[:current] %><span class="lp-mockevo-badge">✨ 今ここ！</span><% end %>
                  <span class="lp-mockevo-name"><%= s[:name] %></span>
                </div>
                <% if i < 3 %><span class="lp-mockevo-arrow">›</span><% end %>
              <% end %>
            </div>
          </div>
          <div class="lp-frame-zoom-hint">🔍 クリックで拡大</div>
        </div>
        <div class="lp-screen-tags">
          <span>育成システム</span><span>Rails Model</span><span>3色×4段階進化</span>
        </div>
      </div>

      <%# 04 部屋の背景テーマ %>
      <div class="lp-screen-card lp-reveal">
        <div class="lp-screen-card-hd">
          <span class="lp-screen-num">04</span>
          <h3 class="lp-screen-info-title">お部屋の背景テーマ</h3>
        </div>
        <p class="lp-screen-card-desc">タスクで貯めたコインを使って、18種類の部屋テーマを解放できる。星空・スイーツ・プリンセスなど、好みのインテリアでリボンちゃんのお部屋をカスタマイズしよう。</p>
        <div class="lp-browser-frame lp-browser-frame--grid" data-lightbox>
          <div class="lp-browser-bar">
            <span class="lp-browser-dot"></span><span class="lp-browser-dot"></span><span class="lp-browser-dot"></span>
            <span class="lp-browser-url">…/shop</span>
          </div>
          <div class="lp-browser-screen lp-screen--deco">
            <%= image_tag "room_sweets.png", class: "lp-screen-room-bg lp-screen-room-bg--deco", alt: "" %>
            <div class="lp-mockdeco-overlay">
              <div class="lp-mockdeco-shop-panel">
                <p class="lp-mockdeco-shop-title">🏠 お部屋の背景テーマ</p>
                <div class="lp-mockdeco-grid">
                  <div class="lp-mockdeco-card lp-mockdeco-card--owned">
                    <%= image_tag "room_stage_1.png", class: "lp-mockdeco-room-thumb", alt: "" %>
                    <span class="lp-mockdeco-card-name">はじめのお部屋</span>
                    <span class="lp-mockdeco-card-badge">FREE</span>
                  </div>
                  <div class="lp-mockdeco-card">
                    <%= image_tag "room_star.png", class: "lp-mockdeco-room-thumb", alt: "" %>
                    <span class="lp-mockdeco-card-name">星空の部屋</span>
                    <span class="lp-mockdeco-card-price">🪙 600</span>
                  </div>
                  <div class="lp-mockdeco-card">
                    <%= image_tag "room_sweets.png", class: "lp-mockdeco-room-thumb", alt: "" %>
                    <span class="lp-mockdeco-card-name">スイーツの部屋</span>
                    <span class="lp-mockdeco-card-price">🪙 300</span>
                  </div>
                  <div class="lp-mockdeco-card">
                    <%= image_tag "room_princess.png", class: "lp-mockdeco-room-thumb", alt: "" %>
                    <span class="lp-mockdeco-card-name">プリンセスの部屋</span>
                    <span class="lp-mockdeco-card-price">🪙 900</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="lp-frame-zoom-hint">🔍 クリックで拡大</div>
        </div>
        <div class="lp-screen-tags">
          <span>18種類のテーマ</span><span>コイン解放</span><span>卵×部屋コンボ</span>
        </div>
      </div>

      <%# 05 ガチャ %>
      <div class="lp-screen-card lp-reveal">
        <div class="lp-screen-card-hd">
          <span class="lp-screen-num">05</span>
          <h3 class="lp-screen-info-title">ガチャシステム</h3>
        </div>
